// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id String @id @default(ulid())

  slug  String @unique
  brand String @db.VarChar(300)
  name  String @unique

  racketWeightU String // example: 3U, 4U, 5U
  weight        Float? // example: 85gr / 89.9gr

  sku           String @unique
  price         Int
  stockQuantity Int
  imageUrl      String
  description   String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
